{
  "name": "timenote",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @timenote/web dev",
    "dev:ext": "pnpm --filter @timenote/extension dev",
    "build": "pnpm --filter @timenote/web build",
    "build:ext": "pnpm --filter @timenote/extension build",
    "deploy:web": "pnpm --filter @timenote/web run deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --config packages/core/vitest.config.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
