{
  "name": "timenote",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @timenote/web dev",
    "dev:ext": "pnpm --filter @timenote/extension dev",
    "build": "pnpm --filter @timenote/web build",
    "build:ext": "pnpm --filter @timenote/extension build",
    "deploy:web": "pnpm --filter @timenote/web run deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --config packages/core/vitest.config.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
